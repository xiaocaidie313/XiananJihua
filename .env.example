# 阿里云 OSS 配置（复制为 .env.local 并填写）
# 注意：AccessKey 不应提交到版本库，生产环境建议使用 STS 临时凭证
VITE_OSS_ACCESS_KEY_ID=
VITE_OSS_ACCESS_KEY_SECRET=
VITE_OSS_BUCKET=xiaoanv
VITE_OSS_REGION=oss-cn-beijing

# 可选：对象路径前缀（默认播客音频 voic/、封面 pics/、视频 vedios/，末尾可带或不带 /）
# VITE_OSS_VOICE_PREFIX=voic
# VITE_OSS_PIC_PREFIX=pics
# VITE_OSS_VIDEO_PREFIX=vedios
